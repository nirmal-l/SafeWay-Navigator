# ─────────────────────────────────────────────
# Fear-Free Night Navigator — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ─── Database (matches docker-compose.yml) ───
DATABASE_URL=postgresql://ffnn_user:ffnn_password@localhost:5433/ffnn_db

# ─── Mapbox (REQUIRED for map rendering) ─────
# Get your free token at: https://account.mapbox.com
# Token starts with 'pk.'
VITE_MAPBOX_TOKEN=PASTE_YOUR_MAPBOX_TOKEN_HERE


# ─── App Config ──────────────────────────────
BACKEND_PORT=8000
ENVIRONMENT=development

# ─── Google Places API (OPTIONAL) ────────────
# Enables real-time business hours & live "eyes on the street" data
# Get free at: https://console.cloud.google.com (Places API)
GOOGLE_PLACES_API_KEY=PASTE_YOUR_KEY_HERE

# ─── Mapbox Traffic API (OPTIONAL) ───────────
# Enables live traffic flow data for "eyes on the street" scoring
# Uses same Mapbox account as your map token
MAPBOX_TRAFFIC_TOKEN=PASTE_YOUR_KEY_HERE

# ─── Jaipur Bounding Box ──────────────────────
# Do not change unless you're switching cities
JAIPUR_MIN_LAT=26.7800
JAIPUR_MIN_LNG=75.7000
JAIPUR_MAX_LAT=27.0200
JAIPUR_MAX_LNG=75.9000
